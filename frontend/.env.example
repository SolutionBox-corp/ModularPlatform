# Copy to .env.local and fill in. None of the server-only vars are exposed to the browser.
BACKEND_URL=http://localhost:5271

# iron-session encryption password. Accepts EITHER a single string (>= 32 chars) OR a JSON
# map of id→password for rotation, e.g. {"1":"<old 32+ secret>","2":"<new 32+ secret>"}.
# When a map is given, the highest id seals NEW cookies while ALL ids still UNSEAL old ones —
# so you rotate by adding a new id, deploying, then dropping the old id later. Every entry
# must be >= 32 chars.
SESSION_PASSWORD=replace-with-a-32+-char-random-secret
# The id that seals new cookies when SESSION_PASSWORD is a bare string (default "1"). With a
# JSON map this is informational — iron-session always seals with the highest numeric id.
SESSION_PASSWORD_ID=1

# Root domain for subdomain-per-tenant routing. Dev: lvh.me:3000 (public DNS → 127.0.0.1).
# Prod: the bare domain, e.g. nasedomena.cz. This single value drives ALL trusted-origin
# allowlists (allowedDevOrigins, Server Actions allowedOrigins, BFF CSRF) via lib/origins.ts —
# the root domain + every subdomain (*.<root>) is trusted, so each tenant works automatically.
ROOT_DOMAIN=lvh.me:3000

# Optional: extra trusted origin hostnames (comma-separated), e.g. Phase-3 vanity domains
# like portal.acme.com. Leave empty unless a tenant brings its own domain.
# ALLOWED_ORIGINS=

# Optional: Redis URL for MULTI-NODE deployments. When set, the BFF single-flight refresh is
# coordinated by a distributed Redis lock (so two nodes can't consume the same one-time refresh
# token). Unset (single-node) keeps the in-process coalescing — no Redis needed.
# REDIS_URL=redis://localhost:6379

# Optional: client-error reporting to /api/log (window.onerror + unhandledrejection +
# global-error). Default true; set to false to disable server-side logging of client errors.
# LOG_CLIENT_ERRORS=true

NEXT_PUBLIC_APP_NAME=ModularPlatform
