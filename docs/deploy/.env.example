# ModularPlatform production env — copy to `/opt/modularplatform/.env` on solutionbox2 and fill in.
# `chmod 600 .env`. NEVER commit the filled file (the repo .gitignore already ignores .env / *.env).
# Generate secrets:
#   openssl rand -base64 48   # Jwt__SigningKey
#   openssl rand -base64 32   # Secrets__MasterKeys__1 (decodes to 32 bytes = AES-256)
#   openssl rand -base64 36   # BlindIndex / RLS runtime pwd / PG admin pwd / SESSION_PASSWORD (>=32 chars)

# ---- environment ----
ASPNETCORE_ENVIRONMENT=Production

# ---- database (HOST PostgreSQL 15 via host-gateway; admin role has BYPASSRLS + CREATEROLE) ----
ConnectionStrings__Write=Host=host.docker.internal;Port=5432;Database=modularplatform;Username=modularplatform_admin;Password=__PG_ADMIN_PWD__
ConnectionStrings__Read=Host=host.docker.internal;Port=5432;Database=modularplatform;Username=modularplatform_admin;Password=__PG_ADMIN_PWD__
Persistence__Rls__Enabled=true
Persistence__Rls__RuntimePassword=__RLS_RUNTIME_PWD__

# ---- fail-fast secrets (host won't boot in Production without these) ----
Jwt__SigningKey=__JWT_SIGNING_KEY_48B_BASE64__
Gdpr__Encryption__BlindIndexKey=__BLIND_INDEX_KEY_MIN_32_CHARS__
Secrets__ActiveKeyVersion=1
Secrets__MasterKeys__1=__SECRETS_MASTER_KEY_32B_BASE64__

# ---- behind nginx -> Next BFF -> Api: trust the compose subnet for X-Forwarded-* ----
ForwardedHeaders__Enabled=true
ForwardedHeaders__KnownNetworks__0=172.28.0.0/16

# ---- external integrations: fakes/off for the first deploy ----
# Stripe validator requires UseFakeGateway=false in Production; keys left empty -> checkout errors only
# at call time, the rest of Billing (credit ledger) works.
Billing__Stripe__UseFakeGateway=false
# Marketing fakes -> no Google/Anthropic cost. Flip to false + add Marketing__Claude__ApiKey / Google creds later.
Marketing__UseFakeGateways=true

# ---- platform-admin bootstrap (gets platform.tenants.manage on login) ----
Identity__Auth__AdminEmails__0=miroslav.lalik@solutionbox.cz

# ---- messaging: dedicated Worker consumes durable queue (Balanced, both Api+Worker false) ----
Messaging__SoloMode=false
# Api does NOT migrate at startup; the one-shot `migrator` service owns migrations + RLS.
RunMigrationsAtStartup=false

# ---- web (Next.js BFF) ----
BACKEND_URL=http://api:8080
SESSION_PASSWORD=__SESSION_PASSWORD_MIN_32_CHARS__
ROOT_DOMAIN=mp.solutionbox.cz
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=ModularPlatform
